// }



"editor.tokenColorCustomizations": 
    {
        "textMateRules": 
            [
                {
                    "scope": "entity.name.tag",
                    "settings": 
                                {
                                    "foreground": "#fdb7fd"
                                    // "foreground": "#ffa078"
                                }
                },
                {
                    "scope": "keyword.operator",
                    "settings": 
                                {
                                    "foreground": "#ff9fcf" // pink
                                    // "foreground": "#ffa078"
                                    // "foreground": "#e45f60" // red
                                }
                }
            ]
    },
    "atlascode.jira.lastCreateSiteAndProject": {
        "siteId": "",
        "projectKey": ""
    },
    "atlascode.jira.explorer.enabled": true,
    "todo-tree.general.tags": [
        "XXX",
        "???",
        "TODO",
        "HACK",
        "FIXME",
        "FIX",
        "BUG",
        "TODO:  fix this"
    ],
    "atlascode.jira.todoIssues.enabled": false,

    // https://github.com/Gruntfuggly/todo-tree#highlighting
    "todo-tree.regex.regex": "((//|--|#|<!--|;|/\\*|^)\\s*($TAGS)|^\\s*- \\[ \\])",
    "todo-tree.highlights.defaultHighlight": {
        "type": "text-and-comment",
        "foreground": "red",
        "fontWeight": "bold",
        "gutterIcon": true,
        "rulerLane" : "full"
    },
    "todo-tree.highlights.customHighlight": {
        "TODO": {
            "foreground" : "#f8936f",
            "rulerColour": "#f8936f",
        },
        "???": {
            "icon"       : "question",
            "foreground" : "#b777f7",
            "rulerColour": "#b777f7",
            "fontStyle"  : "italic",
        },
        "FIX": {
            "icon"       : "flame",
            "foreground" : "yellow",
            "rulerColour": "yellow",
        },
        "BUG": {
            "type"       : "text",
            "foreground" : "green",
            "rulerColour": "green",
        },
        "HACK": {
            "icon"       : "thumbsdown",
            "type"       : "text",
            "foreground" : "green",
            "rulerColour": "green"
        }
    },
    "todo-tree.general.enableFileWatcher": true,
    "todo-tree.general.revealBehaviour": "highlight todo",
    "todo-tree.general.statusBar": "current file",
    "todo-tree.tree.showCountsInTree": true,
